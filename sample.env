# ----------------------------------------------------------------
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git — it contains your password.
# ----------------------------------------------------------------

# The address of the mail server you're sending through.
# Gmail users: use smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# The port the mail server listens on.
# 587 is the standard port for "StartTLS" (an encrypted connection).
SMTP_PORT=587

# The email address you're sending FROM.
# This must be an account on the SMTP_HOST server above.
SMTP_USER=you@gmail.com

# The password for that email account.
# Gmail tip: if you have 2-factor auth on (you should!), you can't use
# your normal password here. Instead generate an "App Password":
# Google Account → Security → 2-Step Verification → App passwords
SMTP_PASS=your-app-password-here

# The email address that will RECEIVE the in-stock alerts.
# Can be the same as SMTP_USER, or a completely different address.
NOTIFY_EMAIL=you@gmail.com

# ── Twilio SMS (optional) ─────────────────────────────────────────────────────
# If these are left blank, SMS is skipped and only email is sent.
# Sign up at https://twilio.com to get your Account SID and Auth Token.
TWILIO_SID=
TWILIO_TOKEN=
# The Twilio phone number assigned to your account (include country code)
TWILIO_FROM=+15005550006
# Your real phone number that will receive the texts (include country code)
TWILIO_TO=+14085550001
